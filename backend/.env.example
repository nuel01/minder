# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Resend (email)
RESEND_API_KEY=re_your_key_here
